APP_NAME="SJ_ARMORY"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://172.16.16.90
APP_TIMEZONE=America/Bogota
AUTH_ALLOW_PUBLIC_REGISTRATION=false
SEED_ADMIN_PASSWORD=
NOMINATIM_USER_AGENT=

LOG_CHANNEL=stack
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=sj_armory
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_CONNECTION=reverb
# Debe coincidir con VITE_BROADCAST_CONNECTION tras compilar el frontend (reverb | pusher).
# En hosting compartido suele usarse pusher (sin proceso Reverb en el servidor).
# Si no quieres tiempo real: BROADCAST_ENABLED=false o BROADCAST_CONNECTION=log
BROADCAST_ENABLED=true
CACHE_DRIVER=file
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120
SESSION_DOMAIN=
SANCTUM_STATEFUL_DOMAINS=sj_armory.test,sj_armory.test:80,SJPCANAOPE1,SJPCANAOPE1:80,172.16.16.90,172.16.16.90:80

MEMCACHED_HOST=127.0.0.1

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# Pusher (Laravel Cloud / pusher.com) — recomendado en hosting compartido
# Cree una app Channels, copie id/key/secret y cluster. En producción use HTTPS (forceTLS).
PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_HOST=
PUSHER_PORT=443
PUSHER_SCHEME=https
PUSHER_APP_CLUSTER=mt1

# Reverb credentials (do NOT commit real secrets)
REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
# Hostname/IP that el navegador usa para el WebSocket (mismo que APP_URL si entran por IP).
# En Windows a veces :8080 está reservado; 6001 suele funcionar sin elevación.
REVERB_HOST=172.16.16.90
REVERB_PORT=6001
REVERB_SCHEME=http
REVERB_SERVER_HOST=0.0.0.0
REVERB_SERVER_PORT=6001

VITE_APP_NAME="${APP_NAME}"
# Mismo modo que BROADCAST_CONNECTION: reverb (local/VPS) o pusher (hosting compartido / cloud)
VITE_BROADCAST_CONNECTION=reverb
VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
VITE_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
VITE_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"
VITE_PUSHER_HOST="${PUSHER_HOST}"
VITE_PUSHER_PORT="${PUSHER_PORT}"
VITE_PUSHER_SCHEME="${PUSHER_SCHEME}"
