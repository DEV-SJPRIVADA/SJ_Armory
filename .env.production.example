# Copiar a .env.production en la raíz del proyecto (está en .gitignore).
# Ese archivo se fusiona con .env al ejecutar: npm run build:deploy
# y sobrescribe VITE_* para que public/build coincida con el hosting (Pusher cloud).

APP_URL=https://sjregistrycat.com

VITE_APP_NAME=SJ_ARMORY
VITE_BROADCAST_CONNECTION=pusher
# Misma clave pública que PUSHER_APP_KEY del servidor (no uses ${...} aquí).
VITE_PUSHER_APP_KEY=
VITE_PUSHER_APP_CLUSTER=us2
VITE_PUSHER_HOST=
VITE_PUSHER_PORT=443
VITE_PUSHER_SCHEME=https
